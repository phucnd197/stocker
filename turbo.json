{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "bin/**", "obj/**"]
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": ["tests/**/*"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "codegen": {
      "cache": false
    }
  }
}
